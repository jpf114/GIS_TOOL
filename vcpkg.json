{
  "name": "gis-tool",
  "version": "0.1.1",
  "description": "GIS toolset based on GDAL and OpenCV with plugin architecture",
  "dependencies": [
    {
      "name": "gdal",
      "default-features": true
    },
    {
      "name": "opencv4",
      "default-features": true
    },
    "proj",
    "gtest",
    {
      "name": "qtbase",
      "default-features": false,
      "features": ["widgets"]
    }
  ],
  "overrides": []
}
