if(POLICY CMP0207)
    cmake_policy(SET CMP0207 NEW)
endif()

set(_gis_install_bin_dir "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@")
set(_gis_install_plugin_dir "${CMAKE_INSTALL_PREFIX}/@GIS_INSTALL_PLUGIN_DIR@")

set(_gis_runtime_executables
    "${_gis_install_bin_dir}/gis-cli.exe"
)

if(EXISTS "${_gis_install_bin_dir}/gis-gui.exe")
    list(APPEND _gis_runtime_executables "${_gis_install_bin_dir}/gis-gui.exe")
endif()

set(_gis_runtime_libraries
    "${_gis_install_plugin_dir}/plugin_projection.dll"
    "${_gis_install_plugin_dir}/plugin_cutting.dll"
    "${_gis_install_plugin_dir}/plugin_matching.dll"
    "${_gis_install_plugin_dir}/plugin_processing.dll"
    "${_gis_install_plugin_dir}/plugin_classification.dll"
    "${_gis_install_plugin_dir}/plugin_vector.dll"
)

file(REMOVE
    "${_gis_install_plugin_dir}/plugin_utility.dll"
    "${CMAKE_INSTALL_PREFIX}/plugins/plugin_utility.dll"
    "${_gis_install_bin_dir}/gmock.dll"
    "${_gis_install_bin_dir}/gmock_main.dll"
    "${_gis_install_bin_dir}/gtest.dll"
    "${_gis_install_bin_dir}/gtest_main.dll"
    "${_gis_install_bin_dir}/Qt6Test.dll"
    "${_gis_install_bin_dir}/advapi32.dll"
    "${_gis_install_bin_dir}/authz.dll"
    "${_gis_install_bin_dir}/bcrypt.dll"
    "${_gis_install_bin_dir}/crypt32.dll"
    "${_gis_install_bin_dir}/d3d11.dll"
    "${_gis_install_bin_dir}/d3d12.dll"
    "${_gis_install_bin_dir}/dbghelp.dll"
    "${_gis_install_bin_dir}/dwmapi.dll"
    "${_gis_install_bin_dir}/dwrite.dll"
    "${_gis_install_bin_dir}/dxgi.dll"
    "${_gis_install_bin_dir}/gdi32.dll"
    "${_gis_install_bin_dir}/iphlpapi.dll"
    "${_gis_install_bin_dir}/kernel32.dll"
    "${_gis_install_bin_dir}/mpr.dll"
    "${_gis_install_bin_dir}/netapi32.dll"
    "${_gis_install_bin_dir}/ntdll.dll"
    "${_gis_install_bin_dir}/ole32.dll"
    "${_gis_install_bin_dir}/oleaut32.dll"
    "${_gis_install_bin_dir}/secur32.dll"
    "${_gis_install_bin_dir}/shell32.dll"
    "${_gis_install_bin_dir}/shlwapi.dll"
    "${_gis_install_bin_dir}/user32.dll"
    "${_gis_install_bin_dir}/userenv.dll"
    "${_gis_install_bin_dir}/uxtheme.dll"
    "${_gis_install_bin_dir}/version.dll"
    "${_gis_install_bin_dir}/winmm.dll"
    "${_gis_install_bin_dir}/ws2_32.dll"
)

set(_gis_can_scan_runtime_deps TRUE)

if(WIN32)
    find_program(_gis_dumpbin_command dumpbin)
    find_program(_gis_llvm_objdump_command llvm-objdump)
    find_program(_gis_objdump_command objdump)

    if(_gis_dumpbin_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL dumpbin)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_dumpbin_command}")
    elseif(_gis_llvm_objdump_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL objdump)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_llvm_objdump_command}")
    elseif(_gis_objdump_command)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_TOOL objdump)
        set(CMAKE_GET_RUNTIME_DEPENDENCIES_COMMAND "${_gis_objdump_command}")
    else()
        set(_gis_can_scan_runtime_deps FALSE)
        message(WARNING "No dumpbin/objdump tool found, fallback to copying vcpkg runtime DLLs directly.")
    endif()
endif()

if(_gis_can_scan_runtime_deps)
    file(GET_RUNTIME_DEPENDENCIES
        EXECUTABLES ${_gis_runtime_executables}
        LIBRARIES ${_gis_runtime_libraries}
        RESOLVED_DEPENDENCIES_VAR _gis_resolved_deps
        UNRESOLVED_DEPENDENCIES_VAR _gis_unresolved_deps
        DIRECTORIES
            "@GIS_VCPKG_RELEASE_BIN_DIR@"
            "@GIS_VCPKG_DEBUG_BIN_DIR@"
        PRE_EXCLUDE_REGEXES
            "api-ms-"
            "ext-ms-"
            "[Hh][Vv][Ss][Ii][Ff]ile[Tt]rust\\.dll"
        POST_EXCLUDE_REGEXES
            ".*/install/bin/.*"
            ".*/[Ww]indows/.*"
            ".*/[Ss]ystem32/.*"
    )

    if(_gis_unresolved_deps)
        list(JOIN _gis_unresolved_deps "\n  " _gis_unresolved_text)
        message(FATAL_ERROR "Unresolved runtime dependencies:\n  ${_gis_unresolved_text}")
    endif()

    set(_gis_filtered_resolved_deps)
    foreach(_gis_dep IN LISTS _gis_resolved_deps)
        get_filename_component(_gis_dep_dir "${_gis_dep}" DIRECTORY)
        file(TO_CMAKE_PATH "${_gis_dep_dir}" _gis_dep_dir_norm)
        file(TO_CMAKE_PATH "${_gis_install_bin_dir}" _gis_install_bin_dir_norm)
        if(_gis_dep_dir_norm STREQUAL _gis_install_bin_dir_norm)
            continue()
        endif()
        list(APPEND _gis_filtered_resolved_deps "${_gis_dep}")
    endforeach()

    list(REMOVE_DUPLICATES _gis_filtered_resolved_deps)

    foreach(_gis_dep IN LISTS _gis_filtered_resolved_deps)
        file(INSTALL
            DESTINATION "${_gis_install_bin_dir}"
            TYPE SHARED_LIBRARY
            FILES "${_gis_dep}"
        )
    endforeach()
else()
    file(GLOB _gis_vcpkg_runtime_dlls "@GIS_VCPKG_RELEASE_BIN_DIR@/*.dll")
    foreach(_gis_dep IN LISTS _gis_vcpkg_runtime_dlls)
        get_filename_component(_gis_dep_name "${_gis_dep}" NAME)
        if(_gis_dep_name MATCHES "^(gmock|gmock_main|gtest|gtest_main)\\.dll$")
            continue()
        endif()
        if(_gis_dep_name STREQUAL "Qt6Test.dll")
            continue()
        endif()
        file(INSTALL
            DESTINATION "${_gis_install_bin_dir}"
            TYPE SHARED_LIBRARY
            FILES "${_gis_dep}"
        )
    endforeach()
endif()
